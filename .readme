│   └── App.tsx
│
flexi-backend/
├── controllers/
│   ├── authController.js
│   ├── appointmentController.js
├── models/
│   ├── Users.js
│   ├── Appointment.js
├── routes/
│   ├── authRoutes.js
│   ├── appointmentRoutes.js
└── server.js
